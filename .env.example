# Backend API server — the data source for water quality, weather, and predictions.
# Replace with your own server URL. No trailing slash.
API_BASE=http://your-backend-server:8000

# Default language when no ?lang= param is in the URL.
# Supported values: de, en
VITE_DEFAULT_LANG=de

# Matomo analytics (optional — omit or leave blank to disable tracking)
VITE_MATOMO_URL=https://your-matomo-instance.example.com/matomo/
VITE_MATOMO_SITE_ID=1